<ul webc:if="items && items.length" class="content-links">
  <li webc:for="link of items">
    <a :href="link.url" @text="link.label"></a>
  </li>
</ul>

<style webc:scoped>
  .content-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
  }

  .content-links a {
    border: 1px solid currentColor;
    border-radius: 4px;
    display: inline-block;
    padding: 0.25rem 0.5rem;
    text-decoration: none;
  }
</style>
