<article class="talk-card content-row">
  <a :href="talk.canonicalUrl">
    <img
      webc:if="talk.media && talk.media.image"
      :src="talk.media.image"
      :alt="talk.media.imageAlt || ''"
      class="talk-card__image"
    >
    <h2 @text="talk.title"></h2>
    <p webc:if="talk.summary" @text="talk.summary"></p>
  </a>
</article>
