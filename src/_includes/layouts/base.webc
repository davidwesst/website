<!doctype html>
<script webc:setup>
  const currentYear = new Date().getFullYear();
</script>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" :content="description || site.description">
  <link webc:keep rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
  <link webc:keep rel="stylesheet" href="/assets/site.css">
  <title @text="title ? `${title} | ${site.title}` : site.title"></title>
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-header">
    <h1 webc:if="page.url === '/'"><a href="/" @text="site.title"></a></h1>
    <p webc:if="page.url !== '/'" class="site-title"><a href="/" @text="site.title"></a></p>
    <site-nav :@items="site.navigation" :@current-url="page.url"></site-nav>
  </header>
  <main id="main" class="site-main" @raw="content"></main>
  <footer class="site-footer">
    <p>Copyright © <span @text="currentYear"></span> David Wesst</p>
    <a href="#">Back to top</a>
  </footer>
  <site-analytics></site-analytics>
</body>
</html>
