<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" :content="description || site.description">
  <title @text="title ? `${title} | ${site.title}` : site.title"></title>
</head>
<body>
  <header webc:if="page.url === '/'" class="site-header">
    <h1><a href="/" @text="site.title"></a></h1>
    <site-nav :@items="site.navigation" :@current-url="page.url"></site-nav>
  </header>
  <site-nav webc:if="page.url !== '/'" :@items="site.navigation" :@current-url="page.url"></site-nav>
  <main @raw="content"></main>
</body>
</html>

<style>
  body {
    margin: 1rem;
  }

  .site-header {
    display: grid;
    gap: 0.5rem;
    margin-block-end: 1rem;
  }

  .site-header h1 {
    margin: 0;
  }
</style>
